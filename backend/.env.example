# ── Gemini configuration ─────────────────────────────────────────────
# Two ways to reach Gemini (an API key, if set, takes priority):
#
# 1. Direct Google Gemini API key (optional server-wide default).
#    Users can also supply their own key per request from the web tool
#    or the browser extension (BYOK) — that key overrides this one.
#    Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Model used for direct API-key calls (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
#
# 2. Self-hosted Gemini proxy URL (used when no API key is available).
#    Example: https://your-gemini-api.onrender.com
GEMINI_API_URL=https://your-gemini-api.onrender.com

# NewsAPI.org API Key (free tier: 100 requests/day)
# Get yours at: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.pages.dev